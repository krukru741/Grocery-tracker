rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - uid: string (required) - User ID
    //   - email: string (optional) - User email
    //   - displayName: string (optional) - User display name
    //   - photoURL: string (optional) - User photo URL
    //   - monthlyBudget: number (optional) - Monthly budget
    //   - createdAt: timestamp (required) - Creation timestamp
    //
    // Collection: users/{userId}/groceries
    // Document ID: {itemId}
    // Fields:
    //   - userId: string (required) - Owner ID
    //   - name: string (required) - Item name
    //   - quantity: number (required) - Quantity
    //   - price: number (required) - Price
    //   - category: string (required) - Category
    //   - barcode: string (optional) - Barcode
    //   - dateAdded: timestamp (required) - Date added
    //   - createdAt: timestamp (required) - Creation timestamp
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function uidUnchanged() {
      return !('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid;
    }
    
    function uidNotModified() {
      return !('uid' in request.resource.data) || request.resource.data.uid == resource.data.uid;
    }
    
    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }
    
    function isValidStringLength(field, minLen, maxLen) {
      return request.resource.data[field] is string &&
        request.resource.data[field].size() >= minLen &&
        request.resource.data[field].size() <= maxLen;
    }
    
    function isValidOptionalString(field, minLen, maxLen) {
      return !(field in request.resource.data) ||
             (request.resource.data[field] is string &&
              request.resource.data[field].size() >= minLen &&
              request.resource.data[field].size() <= maxLen);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    
    function isValidUser() {
      return hasRequiredFields(['uid', 'createdAt']) &&
             request.resource.data.uid == request.auth.uid &&
             request.resource.data.createdAt is timestamp &&
             isValidOptionalString('email', 0, 100) &&
             isValidOptionalString('displayName', 0, 100) &&
             isValidOptionalString('photoURL', 0, 500) &&
             (!( 'monthlyBudget' in request.resource.data ) || (request.resource.data.monthlyBudget is number && request.resource.data.monthlyBudget >= 0));
    }
    
    function isValidGroceryItem(userId) {
      return hasRequiredFields(['userId', 'name', 'quantity', 'price', 'category', 'dateAdded', 'createdAt']) &&
             request.resource.data.userId == userId &&
             isValidStringLength('name', 1, 100) &&
             request.resource.data.quantity is number && request.resource.data.quantity > 0 &&
             request.resource.data.price is number && request.resource.data.price >= 0 &&
             isValidStringLength('category', 1, 50) &&
             isValidOptionalString('barcode', 0, 50) &&
             request.resource.data.dateAdded is timestamp &&
             request.resource.data.createdAt is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser() && uidUnchanged();
      allow update: if isOwner(userId) && isValidUser() && uidNotModified() && request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if isOwner(userId);
      
      match /groceries/{itemId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidGroceryItem(userId);
        allow update: if isOwner(userId) && isValidGroceryItem(userId) && request.resource.data.userId == resource.data.userId && request.resource.data.createdAt == resource.data.createdAt;
        allow delete: if isOwner(userId);
      }
    }
  }
}
